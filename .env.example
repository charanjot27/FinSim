# FinSim environment variables — copy to `.env` and fill in what you have.
# All keys are OPTIONAL. Missing keys → graceful offline fallback with curated data.
#
# ┌────────────────────────────────────────────────────────────────────────────┐
# │  HOW THIS WORKS                                                            │
# │  Every in-game lesson maps to a real-world skill. When these keys are      │
# │  present, the game shows LIVE prices, LIVE news, and LIVE macro stats.     │
# │  Without keys, it falls back to realistic sample data so learning never    │
# │  breaks.                                                                   │
# └────────────────────────────────────────────────────────────────────────────┘

# ── Firebase (Google Sign-in + cloud save of your portfolio) ───────────────
# Get from https://console.firebase.google.com → Project settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Live market data ────────────────────────────────────────────────────────
# Finnhub: https://finnhub.io  (free tier: 60 req/min, US stocks + forex)
VITE_FINNHUB_KEY=
# Alpha Vantage: https://www.alphavantage.co/support/#api-key  (free: 25 req/day)
VITE_ALPHAVANTAGE_KEY=

# ── Live news ───────────────────────────────────────────────────────────────
# NewsAPI: https://newsapi.org/register  (free: 100 req/day, dev only)
VITE_NEWSAPI_KEY=
# Marketaux: https://www.marketaux.com  (free: 100 req/day, ticker-tagged news)
VITE_MARKETAUX_KEY=

# ── Live macro stats ────────────────────────────────────────────────────────
# FRED (Federal Reserve Economic Data): https://fred.stlouisfed.org/docs/api/api_key.html
# Free, unlimited. Used for: Fed funds rate, CPI, unemployment, 10Y yield.
VITE_FRED_KEY=

# ── Blockchain / on-chain ───────────────────────────────────────────────────
# Etherscan: https://etherscan.io/apis  (free: 5 req/s)
# Used for live gas prices. Without a key, we fall back to Cloudflare's public
# Ethereum RPC (keyless, slower).
VITE_ETHERSCAN_KEY=

# ── Mira AI Coach (Cloud Function + Gemini) ────────────────────────────────
# Set to "true" only when running `firebase emulators:start` locally so the
# client routes httpsCallable('miraCoach') to 127.0.0.1:5001 instead of prod.
VITE_FUNCTIONS_EMULATOR=

# Set in Firebase secret store, NOT in this file:
#   firebase functions:secrets:set GEMINI_API_KEY
# (Get a key at https://aistudio.google.com/apikey — free tier covers thousands
# of coach calls per day on Gemini 2.5 Flash.)

# ── Notes ────────────────────────────────────────────────────────────────────
# CoinGecko (crypto), Blockchair (Bitcoin/Ethereum stats), DefiLlama (TVL),
# and the World Bank API (global dev data) are keyless — they work out of the
# box, no signup needed.
